# Copy to .env.local and fill in your RunPod values
NEXT_PUBLIC_BACKEND_URL=https://YOUR-POD-ID-8000.proxy.runpod.net
NEXT_PUBLIC_API_KEY=your-secret-api-key-here

# Used by next.config.js for server-side proxy rewrites (same as BACKEND_URL, no NEXT_PUBLIC_)
BACKEND_URL=https://YOUR-POD-ID-8000.proxy.runpod.net
